<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- The active appender is selected by the LOG_FORMAT system property, which the application
         sets from the active profiles (plain-log -> plain, otherwise -> logstash JSON). -->

    <if condition='isDefined("LOG_FORMAT") &amp;&amp; property("LOG_FORMAT").equals("plain")'>
        <then>
            <!-- ==================== Human-readable (plain-log profile) ==================== -->
            <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                    <layout class="org.example.fullstackstarter.observability.logging.MaskingPatternLayout">
                        <maskPattern>\"x-xsrf-token\"\s*:\s*\"(.*?)\"</maskPattern>
                        <maskPattern>\"JSESSIONID\"\s*:\s*\"(.*?)\"</maskPattern>
                        <maskPattern>\"XSRF-TOKEN\"\s*:\s*\"(.*?)\"</maskPattern>
                        <pattern>%d{HH:mm:ss.SSS} [%thread] [cid=%X{correlationId}] [uid=%X{userId}] [%X{method} %X{uri}] %-5level %logger{36} - %msg%n</pattern>
                    </layout>
                </encoder>
            </appender>

            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
            </root>
        </then>
        <else>
            <!-- ==================== JSON structured (default) ==================== -->
            <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="org.example.fullstackstarter.observability.logging.MaskingStructuredLogEncoder">
                    <charset>UTF-8</charset>
                    <customFields>{"service":"fullstack-starter","app_version":"main-SNAPSHOT"}</customFields>
                    <maskPattern>\"x-xsrf-token\"\s*:\s*\"(.*?)\"</maskPattern>
                    <maskPattern>\"JSESSIONID\"\s*:\s*\"(.*?)\"</maskPattern>
                    <maskPattern>\"XSRF-TOKEN\"\s*:\s*\"(.*?)\"</maskPattern>
                </encoder>
            </appender>

            <root level="INFO">
                <appender-ref ref="CONSOLE_JSON"/>
            </root>
        </else>
    </if>

</configuration>
